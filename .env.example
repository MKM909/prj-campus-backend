NODE_ENV=development
PORT=5000

# Supabase
# Dashboard -> Project Settings -> API Keys / Connect
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Current custom Express JWT flow.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Comma-separated when you have multiple dashboards/frontends.
CLIENT_URLS=http://localhost:5173,https://your-admin-dashboard.vercel.app

# Google sign-in. Create this in Google Cloud Console.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# AI
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Cloudinary unsigned upload config
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_UPLOAD_PRESET=prjcampus

# Maps
MAPTILER_AI_KEY=your-maptiler-api-key
